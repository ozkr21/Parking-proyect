generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  PORTERO
  COPROPIETARIO
}

enum RequestStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum VehicleType {
  CARRO
  MOTO
}

// ─────────────────────────────────────────
// MODELOS
// ─────────────────────────────────────────

model Apartment {
  id         String @id @default(cuid())
  tower      String
  floor      Int
  number     String
  identifier String @unique

  residents       User[]
  vehicle         Vehicle?         // máximo 1 vehículo residente
  vehicleRequests VehicleRequest[]
  visitors        VisitorVehicle[] // ilimitados visitantes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tower])
  @@index([identifier])
}

model User {
  id                 String  @id @default(cuid())
  name               String
  email              String  @unique
  password           String
  role               Role
  mustChangePassword Boolean @default(true)

  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id])

  vehicleRequests  VehicleRequest[] @relation("RequestedBy")
  reviewedRequests VehicleRequest[] @relation("ReviewedBy")
  vehiclesCreated  Vehicle[]        @relation("CreatedBy")
  visitorsCreated  VisitorVehicle[] @relation("VisitorCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// Vehículos residentes (CARRO o MOTO)
// Máximo 1 por apartamento garantizado por @unique en apartmentId
model Vehicle {
  id    String      @id @default(cuid())
  plate String      @unique
  color String
  model String
  type  VehicleType // CARRO | MOTO

  // ─── Bloqueo ─────────────────────────────────
  isBlocked Boolean @default(false)
  blockNote String?

  // ─── Relaciones ──────────────────────────────
  apartmentId String    @unique // @unique = máx 1 residente por apartamento
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plate])
  @@index([apartmentId])
  @@index([isBlocked])
  @@index([type])
}

// Vehículos visitantes
// Sin límite por apartamento, placa única en el sistema
model VisitorVehicle {
  id    String @id @default(cuid())
  plate String @unique // placa única — se actualiza si el mismo carro vuelve
  color String
  model String

  // ─── Bloqueo ─────────────────────────────────
  isBlocked Boolean @default(false)
  blockNote String?

  // ─── Apartamento que visita ───────────────────
  visitingApartmentId String
  visitingApartment   Apartment @relation(fields: [visitingApartmentId], references: [id])

  // ─── Fecha y hora de entrada ──────────────────
  visitEntryAt DateTime @default(now())

  // ─── Quién lo registró (solo portero o admin) ─
  createdById String
  createdBy   User   @relation("VisitorCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plate])
  @@index([visitingApartmentId])
  @@index([isBlocked])
  @@index([visitEntryAt])
}

// Solicitudes de vehículos (solo copropietarios, solo residentes)
model VehicleRequest {
  id     String        @id @default(cuid())
  plate  String
  color  String
  model  String
  type   VehicleType   // CARRO | MOTO (no aplica VISITANTE)
  status RequestStatus @default(PENDIENTE)

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  createdById String
  createdBy   User   @relation("RequestedBy", fields: [createdById], references: [id])

  reviewedById String?
  reviewedBy   User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])

  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([apartmentId])
  @@index([type])
}